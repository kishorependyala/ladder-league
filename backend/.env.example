# Path to the data directory containing users.json, leagues.json, and scores/
# Local development: point to the repo's data folder (default if unset)
DATA_DIR=../data

# Azure example: use an Azure Files mount or absolute path
# DATA_DIR=/mnt/ladder-league-data

# SMTP settings for PIN reset emails (leave blank to disable email sending)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=
